{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://example.com/publisher/app-config.schema.json",
	"title": "Publisher app config",
	"type": "object",
	"additionalProperties": false,
	"required": [
		"title",
		"description",
		"site",
		"defaultFile",
		"home",
		"github",
		"localFallback",
		"externalLinks",
		"maps",
		"reading",
		"obsidian",
		"linktree",
		"contentRights",
		"metadata",
		"pageLoadAnimation",
		"appearance",
		"features"
	],
	"properties": {
		"$schema": {
			"type": "string"
		},
		"title": {
			"type": "string",
			"minLength": 1
		},
		"description": {
			"type": "string"
		},
		"site": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"url",
				"hashRouting"
			],
			"properties": {
				"url": {
					"type": "string",
					"description": "Public site URL used when copying hash-based article links."
				},
				"customDomain": {
					"type": "string",
					"description": "Optional custom domain URL that overrides the GitHub Pages URL in copied article links."
				},
				"hashRouting": {
					"type": "boolean",
					"description": "Whether hash-based note deep links are enabled."
				}
			}
		},
		"defaultFile": {
			"type": "string",
			"description": "Markdown path to open when choosing an initial note."
		},
		"home": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"title",
				"subtitle",
				"ctas",
				"background"
			],
			"properties": {
				"title": {
					"type": "string",
					"minLength": 1
				},
				"subtitle": {
					"type": "string"
				},
				"ctas": {
					"type": "array",
					"maxItems": 4,
					"items": {
						"type": "object",
						"additionalProperties": false,
						"required": [
							"title",
							"path"
						],
						"properties": {
							"title": {
								"type": "string",
								"minLength": 1
							},
							"description": {
								"type": "string"
							},
							"path": {
								"type": "string",
								"minLength": 1
							}
						}
					}
				},
				"background": {
					"type": "object",
					"additionalProperties": false,
					"required": [
						"enabled",
						"image",
						"grayscale"
					],
					"properties": {
						"enabled": {
							"type": "boolean"
						},
						"image": {
							"type": "string",
							"description": "Optional background image path for the home screen."
						},
						"grayscale": {
							"type": "boolean",
							"description": "Whether the home background image should render in grayscale."
						}
					}
				}
			}
		},
		"github": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"enabled",
				"owner",
				"repo",
				"branch",
				"rootPath",
				"assetRootPath"
			],
			"properties": {
				"enabled": {
					"type": "boolean"
				},
				"owner": {
					"type": "string"
				},
				"repo": {
					"type": "string"
				},
				"branch": {
					"type": "string",
					"minLength": 1
				},
				"rootPath": {
					"type": "string",
					"description": "Optional markdown root directory inside the GitHub repository."
				},
				"assetRootPath": {
					"type": "string",
					"description": "Optional media asset root directory inside the GitHub repository."
				}
			}
		},
		"localFallback": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"enabled",
				"manifest"
			],
			"properties": {
				"enabled": {
					"type": "boolean"
				},
				"manifest": {
					"type": "string"
				}
			}
		},
		"externalLinks": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"utm"
			],
			"properties": {
				"utm": {
					"type": "object",
					"additionalProperties": false,
					"required": [
						"enabled",
						"params"
					],
					"properties": {
						"enabled": {
							"type": "boolean"
						},
						"params": {
							"type": "object",
							"additionalProperties": {
								"type": "string"
							},
							"propertyNames": {
								"pattern": "^utm_[a-z0-9_]+$"
							}
						}
					}
				}
			}
		},
		"maps": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"enabled",
				"fallback",
				"grayscale"
			],
			"properties": {
				"enabled": {
					"type": "boolean"
				},
				"fallback": {
					"type": "object",
					"additionalProperties": false,
					"required": [
						"latitude",
						"longitude",
						"zoom"
					],
					"properties": {
						"latitude": {
							"type": "number",
							"minimum": -90,
							"maximum": 90
						},
						"longitude": {
							"type": "number",
							"minimum": -180,
							"maximum": 180
						},
						"zoom": {
							"type": "number",
							"minimum": 0,
							"maximum": 22
						}
					}
				},
				"grayscale": {
					"type": "boolean"
				}
			}
		},
		"appearance": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"fontSize",
				"textAlign",
				"lineHeight",
				"theme",
				"firstDayOfWeek"
			],
			"properties": {
				"fontSize": {
					"type": "integer",
					"minimum": 14,
					"maximum": 24
				},
				"textAlign": {
					"type": "string",
					"enum": [
						"left",
						"center",
						"justify",
						"right"
					]
				},
				"lineHeight": {
					"type": "number",
					"minimum": 1.2,
					"maximum": 2.2
				},
				"theme": {
					"type": "string",
					"enum": [
						"light",
						"sand",
						"ocean",
						"dark"
					]
				},
				"firstDayOfWeek": {
					"type": "integer",
					"minimum": 0,
					"maximum": 6,
					"description": "0 is Sunday, 1 is Monday, and 6 is Saturday."
				}
			}
		},
		"reading": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"wordsPerMinute"
			],
			"properties": {
				"wordsPerMinute": {
					"type": "integer",
					"minimum": 1,
					"description": "Reading speed used to estimate article reading time."
				}
			}
		},
		"obsidian": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"vault",
				"rootPath"
			],
			"properties": {
				"vault": {
					"type": "string",
					"description": "Obsidian vault name used by obsidian://open links."
				},
				"rootPath": {
					"type": "string",
					"description": "Optional path prefix inside the Obsidian vault."
				}
			}
		},
		"linktree": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"links"
			],
			"properties": {
				"links": {
					"type": "array",
					"items": {
						"type": "object",
						"additionalProperties": false,
						"required": [
							"label",
							"type",
							"url"
						],
						"properties": {
							"label": {
								"type": "string",
								"minLength": 1
							},
							"type": {
								"type": "string",
								"minLength": 1,
								"description": "Icon hint such as youtube, instagram, x, discord, github, website, or email."
							},
							"url": {
								"type": "string",
								"minLength": 1
							}
						}
					}
				}
			}
		},
		"contentRights": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"copyright",
				"license"
			],
			"properties": {
				"copyright": {
					"type": "string",
					"description": "Default copyright text shown for every article unless frontmatter overrides it."
				},
				"license": {
					"type": "string",
					"description": "Default license shown for every article unless frontmatter overrides it."
				}
			}
		},
		"metadata": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"allowedKeys"
			],
			"properties": {
				"allowedKeys": {
					"type": "array",
					"items": {
						"type": "string",
						"minLength": 1
					},
					"description": "Frontmatter keys allowed to appear in the Metadata block."
				}
			}
		},
		"pageLoadAnimation": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"enabled",
				"logo",
				"durationMs",
				"fadeMs"
			],
			"properties": {
				"enabled": {
					"type": "boolean"
				},
				"logo": {
					"type": "string",
					"description": "Logo image path shown in the page load mask."
				},
				"durationMs": {
					"type": "integer",
					"minimum": 0,
					"description": "Minimum time the load animation remains visible."
				},
				"fadeMs": {
					"type": "integer",
					"minimum": 0,
					"description": "Fade-out duration for the logo and black mask."
				}
			}
		},
		"features": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"showFrontmatter",
				"showBacklinks",
				"showGraph"
			],
			"properties": {
				"showFrontmatter": {
					"type": "boolean"
				},
				"showBacklinks": {
					"type": "boolean"
				},
				"showGraph": {
					"type": "boolean"
				}
			}
		}
	}
}
